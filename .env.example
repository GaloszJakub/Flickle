# TMDB credentials — use ONE of these in VITE_TMDB_API_TOKEN:
# - API Key (v3): short hex string from themoviedb.org/settings/api
# - Read Access Token (v4): long JWT starting with "eyJ..."
VITE_TMDB_API_TOKEN=your_tmdb_api_key_or_read_access_token

# Optional: host port for docker compose (default 8080)
# FLICKLE_PORT=8080

# Vercel: ustaw tę samą zmienną w Project Settings → Environment Variables
# (Production + Preview), potem zrób redeploy.
